{
  "name": "yt-video-analyzer",
  "version": "1.0.0",
  "description": "CLI tool to analyze YouTube videos with AI-powered summaries and credibility reports",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "yt-analyze": "./dist/index.js"
  },
  "scripts": {
    "postinstall": "node scripts/patch-youtube-transcript.cjs",
    "dev": "tsx src/index.ts",
    "dev:server": "tsx watch server/index.ts",
    "dev:web": "cd web && npm run dev",
    "dev:all": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build": "tsc",
    "build:web": "cd web && npm install && npm run build",
    "build:all": "npm run build:web && npm run build",
    "start": "node dist/index.js",
    "start:server": "node dist/server/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "chalk": "^4.1.2",
    "cors": "^2.8.6",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "googleapis": "^171.4.0",
    "ora": "^9.3.0",
    "partial-json": "^0.1.7",
    "youtube-transcript": "^1.3.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.5.0",
    "concurrently": "^9.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
